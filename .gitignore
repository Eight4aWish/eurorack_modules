# Build outputs (local only)
build_artifacts/
.pio/

# VS Code local settings caches
.vscode/**
!.vscode/settings.json
!.vscode/c_cpp_properties.json

# Platform-specific temp files
.DS_Store

# Do not track embedded Daisy libraries here
libs/daisy_duino/
.pio/
.DS_Store
build/
/EuroPi

# Per-developer WiFi / OTA credentials (use the .example file as a template)
src/*/secrets.h

# Python tools (tools/llm-proxy/) — virtualenv, byte-cache, build metadata
**/.venv/
**/__pycache__/
**/*.egg-info/

# Per-user secrets (API keys, hostnames). Use .env.example as a template.
**/.env

# Per-user saved data (LLM proxy bank library, runtime logs)
tools/llm-proxy/banks.json
tools/llm-proxy/banks.json.tmp
tools/llm-proxy/proxy.log
