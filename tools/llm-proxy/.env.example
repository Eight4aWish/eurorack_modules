# Copy this file to `.env` and fill in your values. The proxy reads it at
# startup via python-dotenv, so you don't have to `export` on every shell.
# `.env` is gitignored.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: if set, the proxy POSTs generated patches straight to the module.
MODULE_HOST=http://CortHex-ESP32.local
APPLY_TO_MODULE=1

# Optional model / behaviour overrides (defaults shown).
# ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_MAX_TOKENS=4096
# ANTHROPIC_EFFORT=high
# ANTHROPIC_THINKING=adaptive
