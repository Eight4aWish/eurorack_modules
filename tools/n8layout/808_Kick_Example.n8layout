            .screen-print-filled{stroke:white;
            stroke-width: 0.1;fill:white}
            .hole-shadow{fill:#267332}
            .solder-pad{fill:#cccccc;stroke:none}
            .solder-pad-outline{fill:#aaaaaa;stroke:none}
            .n8bbtext{
                text-anchor:middle;
                dominant-baseline:middle;
                font-family:sans-serif;
               font-size: 1.8px;
               fill:white;
               stroke:none;
               user-select: none;
               /* Safari specific */
               -webkit-user-select:none;
               cursor:default;
            }
            
            .n8bblabel{
                 font-family:sans-serif;
                font-size: 1.4px;
                font-weight: bold;
                fill:white;
                stroke:none;
                user-select: none;
                /* Safari specific */
                -webkit-user-select:none;
                cursor:default;
            }

            .n8bbtext-sm{
                text-anchor:middle;
                 dominant-baseline:middle;
                 font-family:sans-serif;
                font-size: 1px;
                fill:white;
                stroke:none;
                user-select: none;
                /* Safari specific */
                -webkit-user-select:none;
                cursor:default;
            }
            
