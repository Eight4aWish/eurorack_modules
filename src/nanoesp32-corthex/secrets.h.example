// secrets.h.example — copy this file to `secrets.h` (in the same folder)
// and fill in your actual values. `secrets.h` is gitignored.
//
//     cp secrets.h.example secrets.h
//     # then edit secrets.h
//
// Used by main.cpp for WiFi connection and OTA authentication.

#pragma once

// Home / studio WiFi network the module should join.
#define WIFI_SSID "your-network-name"
#define WIFI_PASS "your-network-password"

// OTA upload password — required for `pio run -e ai-module-bringup-ota -t upload`.
// Pick anything; just keep it consistent with the upload command.
#define OTA_PASS  "change-me"

// mDNS hostname. Module will be reachable as <OTA_HOST>.local on the LAN.
#define OTA_HOST  "aimodule"
